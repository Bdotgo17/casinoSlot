# Shopify Store Configuration
# Replace these values with your actual Shopify store credentials

# Your Shopify store domain (e.g., my-store.myshopify.com)
SHOPIFY_DOMAIN=your-store.myshopify.com

# Shopify Storefront API access token (found in your Shopify admin under Apps > Develop apps)
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# Webhook secret for verifying Shopify order webhooks
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# Port to run the server on
PORT=3000
